<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ResumeApp"
             xmlns:converters="clr-namespace:ResumeApp.Converters"
             x:Class="ResumeApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolConverter x:Key="inverseBoolean" />
            <converters:InverseIntToBoolConverter x:Key="inverseIntToBool" />

        </ResourceDictionary>
    </Application.Resources>
</Application>