<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.ForgotPasswordPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="24,60,24,24"
            VerticalOptions="Center">

            <!-- ── INPUT FORM (hidden once code is sent) ── -->
            <VerticalStackLayout Spacing="16" IsVisible="{Binding CodeSent, Converter={StaticResource InverseBoolConverter}}">

                <Label Text="Forgot Password?"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1A1A2E" />

                <Label Text="Enter the email address you used to sign up and we'll send you a reset code."
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6C757D"
                       Margin="0,0,0,24" />

                <Frame BorderColor="#DEE2E6" BackgroundColor="White"
                       CornerRadius="8" Padding="4,0" HasShadow="False">
                    <Entry Placeholder="Email address"
                           Keyboard="Email"
                           Text="{Binding Email}"
                           FontSize="15" TextColor="#1A1A2E"
                           PlaceholderColor="#ADB5BD" />
                </Frame>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#DC3545"
                       FontSize="13"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasError}" />

                <!-- Shown when the account exists but OTP hasn't been completed -->
                <Frame IsVisible="{Binding RequiresVerification}"
                       BorderColor="#FFC107"
                       BackgroundColor="#FFF8E1"
                       CornerRadius="8"
                       Padding="16"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Email not verified"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#856404" />
                        <Label Text="Your account exists but your email hasn't been verified yet. Please verify your email before resetting your password."
                               FontSize="13"
                               TextColor="#856404" />
                        <Button Text="Verify Email Now"
                                Command="{Binding GoToVerifyCommand}"
                                BackgroundColor="#1A1A2E"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="14"
                                CornerRadius="8"
                                HeightRequest="44" />
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Send Reset Code"
                        Command="{Binding SendResetLinkCommand}"
                        BackgroundColor="#1A1A2E"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="50"
                        Margin="0,8,0,0" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#1A1A2E"
                                   HorizontalOptions="Center" />

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Margin="0,16,0,0">
                    <Label Text="Remember your password? "
                           FontSize="14"
                           TextColor="#6C757D"
                           VerticalOptions="Center" />
                    <Label Text="Sign In"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1A1A2E"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

            <!-- ── CHECK YOUR EMAIL confirmation (shown after submit) ── -->
            <VerticalStackLayout Spacing="20" IsVisible="{Binding CodeSent}" HorizontalOptions="Center">

                <Label Text="&#x2709;"
                       FontSize="64"
                       TextColor="#1A1A2E"
                       HorizontalOptions="Center" />

                <Label Text="Check your email"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1A1A2E" />

                <Label FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6C757D">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="If " />
                            <Span Text="{Binding Email}" FontAttributes="Bold" TextColor="#1A1A2E" />
                            <Span Text=" is registered with us, you'll find a 6-digit reset code in your inbox." />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Button Text="Enter Reset Code"
                        Command="{Binding EnterCodeCommand}"
                        BackgroundColor="#1A1A2E"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="50"
                        Margin="0,8,0,0" />

                <Label Text="Try a different email"
                       FontSize="14"
                       TextColor="#6C757D"
                       HorizontalOptions="Center"
                       TextDecorations="Underline"
                       Margin="0,4,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TryDifferentEmailCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
