<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.ForgotPasswordPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="28,60,28,28" VerticalOptions="Center">

            <!-- INPUT FORM (hidden once code is sent) -->
            <VerticalStackLayout Spacing="14" IsVisible="{Binding CodeSent, Converter={StaticResource InverseBoolConverter}}">

                <Label Text="&#xf084;"
                       FontFamily="FASolid"
                       FontSize="56"
                       HorizontalOptions="Center" />

                <Label Text="Forgot Password?"
                       FontSize="26"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextPrimary}" />

                <Label Text="Enter your email and we'll send you a reset code."
                       Style="{StaticResource SubtitleStyle}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,16" />

                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource CardBorder}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 12"
                        Padding="4,0">
                    <Entry Placeholder="Email address"
                           Keyboard="Email"
                           Text="{Binding Email}"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource DangerRed}"
                       FontSize="13"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasError}" />

                <!-- Verification warning -->
                <Border IsVisible="{Binding RequiresVerification}"
                        BackgroundColor="#FFFBEB"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource AccentAmber}"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Email not verified"
                               FontSize="15"
                               FontFamily="OpenSansSemibold"
                               TextColor="#92400E" />
                        <Label Text="Your account exists but your email hasn't been verified yet. Please verify before resetting your password."
                               FontSize="13"
                               TextColor="#92400E" />
                        <Button Text="Verify Email Now"
                                Command="{Binding GoToVerifyCommand}"
                                Style="{StaticResource VioletButtonStyle}"
                                HeightRequest="44" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Send Reset Code"
                        Command="{Binding SendResetLinkCommand}"
                        Style="{StaticResource VioletButtonStyle}"
                        Margin="0,8,0,0">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="16" Opacity="0.30" />
                    </Button.Shadow>
                </Button>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource PrimaryViolet}"
                                   HorizontalOptions="Center" />

                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,16,0,0">
                    <Label Text="Remember your password? "
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           VerticalOptions="Center" />
                    <Label Text="Sign In"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource PrimaryViolet}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

            <!-- CHECK YOUR EMAIL confirmation (shown after submit) -->
            <VerticalStackLayout Spacing="20" IsVisible="{Binding CodeSent}" HorizontalOptions="Center">

                <Label Text="&#xf0e0;"
                       FontFamily="FASolid"
                       FontSize="64"
                       HorizontalOptions="Center" />

                <Label Text="Check your email"
                       FontSize="26"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextPrimary}" />

                <Label FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource TextSecondary}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="If " />
                            <Span Text="{Binding Email}"
                                  FontFamily="OpenSansSemibold"
                                  TextColor="{StaticResource TextPrimary}" />
                            <Span Text=" is registered, you'll find a 6-digit reset code in your inbox." />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Button Text="Enter Reset Code"
                        Command="{Binding EnterCodeCommand}"
                        Style="{StaticResource VioletButtonStyle}"
                        Margin="0,8,0,0" />

                <Label Text="Try a different email"
                       FontSize="14"
                       TextColor="{StaticResource PrimaryViolet}"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       Margin="0,4,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TryDifferentEmailCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
