<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="28,60,28,28" VerticalOptions="Center">

            <!-- Logo -->
            <Border WidthRequest="72" HeightRequest="72"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource PrimaryViolet}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,4">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="20" Opacity="0.35" />
                </Border.Shadow>
                <Label Text="✦" FontSize="32" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Text="Create Account"
                   FontSize="26"
                   FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Start building tailored resumes"
                   Style="{StaticResource SubtitleStyle}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16" />

            <Border BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                <Entry Placeholder="First name" Text="{Binding FirstName}"
                       FontSize="15" TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                <Entry Placeholder="Last name" Text="{Binding LastName}"
                       FontSize="15" TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                <Entry Placeholder="Email address" Keyboard="Email" Text="{Binding Email}"
                       FontSize="15" TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}"
                       FontSize="15" TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                <Entry Placeholder="Confirm password" IsPassword="True" Text="{Binding ConfirmPassword}"
                       FontSize="15" TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />

            <Button Text="Create Account"
                    Command="{Binding RegisterCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,8,0,0">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="16" Opacity="0.30" />
                </Button.Shadow>
            </Button>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}"
                               HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,16,0,0">
                <Label Text="Already have an account? "
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center" />
                <Label Text="Sign In"
                       FontSize="14"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource PrimaryViolet}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
