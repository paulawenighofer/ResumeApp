<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             x:Name="RegisterPageRoot"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="28,60,28,28" VerticalOptions="Center">

            <!-- Logo -->
            <Border WidthRequest="72" HeightRequest="72"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource PrimaryViolet}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,4">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="20" Opacity="0.35" />
                </Border.Shadow>
                <Label Text="&#xf005;" FontFamily="FASolid" FontSize="32" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Text="Create Account"
                   FontSize="26"
                   FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
            <Label Text="Start building tailored resumes in minutes."
                   Style="{StaticResource SubtitleStyle}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10" />

            <Border Style="{StaticResource CardStyle}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="First name" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                        <Entry Placeholder="John" Text="{Binding FirstName}"
                               FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                               PlaceholderColor="{StaticResource InactiveIcon}" />
                    </Border>
                    <Label Text="{Binding FirstNameValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasFirstNameValidation}" />

                    <Label Text="Last name" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                        <Entry Placeholder="Doe" Text="{Binding LastName}"
                               FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                               PlaceholderColor="{StaticResource InactiveIcon}" />
                    </Border>
                    <Label Text="{Binding LastNameValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasLastNameValidation}" />

                    <Label Text="Email" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="4,0">
                        <Entry Placeholder="you@example.com" Keyboard="Email" Text="{Binding Email}"
                               FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                               PlaceholderColor="{StaticResource InactiveIcon}" />
                    </Border>

                    <ScrollView Orientation="Horizontal"
                                IsVisible="{Binding ShowEmailSuggestions}"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding EmailSuggestions}"
                                               Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource EmailChipBgLight}, Dark={StaticResource EmailChipBgDark}}"
                                            Stroke="{AppThemeBinding Light={StaticResource EmailChipStrokeLight}, Dark={StaticResource EmailChipStrokeDark}}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="10,4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference RegisterPageRoot}, Path=BindingContext.ApplyEmailSuggestionCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding .}"
                                               FontSize="12"
                                               TextColor="{StaticResource PrimaryViolet}" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Label Text="{Binding EmailValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasEmailValidation}" />

                    <Label Text="Password" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" Margin="0,4,0,0" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="8,0">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0" Placeholder="At least 8 characters" IsPassword="{Binding IsPasswordHidden}" Text="{Binding Password}"
                                   FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                                   PlaceholderColor="{StaticResource InactiveIcon}" />
                            <Label Grid.Column="1"
                                   Text="{Binding PasswordToggleIcon}"
                                   FontFamily="FASolid"
                                   FontSize="16"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                    <Label Text="{Binding PasswordValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasPasswordValidation}" />

                    <Label Text="Confirm password" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="8,0">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0" Placeholder="Re-enter password" IsPassword="{Binding IsConfirmPasswordHidden}" Text="{Binding ConfirmPassword}"
                                   FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                                   PlaceholderColor="{StaticResource InactiveIcon}" />
                            <Label Grid.Column="1"
                                   Text="{Binding ConfirmPasswordToggleIcon}"
                                   FontFamily="FASolid"
                                   FontSize="16"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                    <Label Text="{Binding ConfirmPasswordValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasConfirmPasswordValidation}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />

            <Button Text="Create Account"
                    Command="{Binding RegisterCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,8,0,0">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="16" Opacity="0.30" />
                </Button.Shadow>
            </Button>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}"
                               HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,16,0,0">
                <Label Text="Already have an account? "
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center" />
                <Label Text="Sign In"
                       FontSize="14"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource PrimaryViolet}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
