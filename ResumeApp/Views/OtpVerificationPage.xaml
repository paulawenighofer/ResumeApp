<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.OtpVerificationPage"
             x:DataType="vm:OtpVerificationViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="28,40,28,28" VerticalOptions="Center">

            <controls:PageHeader Title="Verify Email" />

            <Label Text="&#xf0e0;"
                   FontFamily="FASolid"
                   FontSize="56"
                   HorizontalOptions="Center" />

            <Label Text="Check Your Email"
                   FontSize="26"
                   FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

            <Label FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,16">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="We sent a 6-digit code to " />
                        <Span Text="{Binding Email}"
                              FontFamily="OpenSansSemibold"
                              TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Padding="4,0">
                <Entry Placeholder="Enter 6-digit code"
                       Keyboard="Numeric"
                       MaxLength="6"
                       Text="{Binding Code}"
                       FontSize="24"
                       FontFamily="OpenSansSemibold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                       PlaceholderColor="{StaticResource InactiveIcon}"
                       HorizontalTextAlignment="Center" />
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding ResendMessage}"
                   TextColor="{StaticResource SuccessGreen}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasResendMessage}" />

            <Button Text="Verify Email"
                    Command="{Binding VerifyCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,8,0,0">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="16" Opacity="0.30" />
                </Button.Shadow>
            </Button>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}"
                               HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,16,0,0">
                <Label Text="Didn't receive a code? "
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center" />
                <Label Text="Resend"
                       FontSize="14"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource PrimaryViolet}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ResendCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
