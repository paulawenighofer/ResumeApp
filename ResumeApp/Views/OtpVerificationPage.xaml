<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.OtpVerificationPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="24,60,24,24"
            VerticalOptions="Center">

            <Label Text="Check Your Email"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1A1A2E" />

            <Label FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#6C757D"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,24">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="We sent a 6-digit code to " />
                        <Span Text="{Binding Email}" FontAttributes="Bold" TextColor="#1A1A2E" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Frame BorderColor="#DEE2E6" BackgroundColor="White"
                   CornerRadius="8" Padding="4,0" HasShadow="False">
                <Entry Placeholder="Enter 6-digit code"
                       Keyboard="Numeric"
                       MaxLength="6"
                       Text="{Binding Code}"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1A1A2E"
                       PlaceholderColor="#ADB5BD"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="#DC3545"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding ResendMessage}"
                   TextColor="#198754"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasResendMessage}" />

            <Button Text="Verify Email"
                    Command="{Binding VerifyCommand}"
                    BackgroundColor="#1A1A2E"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,8,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1A1A2E"
                               HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center"
                                   Margin="0,16,0,0">
                <Label Text="Didn't receive a code? "
                       FontSize="14"
                       TextColor="#6C757D"
                       VerticalOptions="Center" />
                <Label Text="Resend"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#1A1A2E"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ResendCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
