<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             xmlns:models="clr-namespace:ResumeApp.Models"
             x:Class="ResumeApp.Views.ResumeDraftDetailPage"
             x:DataType="vm:ResumeDraftDetailViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing"
                                        Command="{Binding AppearingCommand}" />
        <toolkit:EventToCommandBehavior EventName="Disappearing"
                                        Command="{Binding DisappearingCommand}" />
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">
            <controls:PageHeader Title="Draft Preview" />

            <Label FontSize="24"
                   FontFamily="OpenSansSemibold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                   Text="Resume Draft" />

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding TargetCompany}"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

                    <Border Padding="10,4"
                            Stroke="{Binding StatusColorHex}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource StatusBadgeBgLight}, Dark={StaticResource StatusBadgeBgDark}}"
                            StrokeShape="RoundRectangle 12"
                            HorizontalOptions="Start">
                        <Label Text="{Binding StatusText}"
                               FontSize="12"
                               FontFamily="OpenSansSemibold"
                               TextColor="{Binding StatusColorHex}" />
                    </Border>

                    <Label Text="{Binding FailedReason}"
                           IsVisible="{Binding HasFailedReason}"
                           TextColor="{StaticResource DangerRed}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}"
                   TextColor="{StaticResource DangerRed}" />

            <!-- Status Messages for Edits -->
            <Border IsVisible="{Binding ShowSaveDraftStatus}"
                    Padding="12,8"
                    Stroke="{StaticResource SuccessGreen}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBoxBgLight}, Dark={StaticResource SuccessBoxBgDark}}"
                    StrokeShape="RoundRectangle 8">
                <Label Text="{Binding SaveDraftStatusMessage}"
                       FontSize="13"
                       TextColor="{StaticResource SuccessGreen}" />
            </Border>

            <CollectionView ItemsSource="{Binding Sections}"
                            IsVisible="{Binding HasSections}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ResumePreviewSection">
                        <Border Margin="0,0,0,12"
                                Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}" Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Label Text="{Binding .}"
                                                   FontSize="13"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />

            <!-- Action Buttons -->
            <VerticalStackLayout Spacing="8" 
                                 IsVisible="{Binding CanEdit, Mode=OneWay}"
                                 Margin="0,16,0,0">
                <Button Text="Save Draft Edits"
                        Command="{Binding SaveDraftEditCommand}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Style="{StaticResource VioletButtonStyle}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8" 
                                 IsVisible="{Binding CanApprove, Mode=OneWay}"
                                 Margin="0,16,0,0">
                <Button Text="Approve and Finalize"
                        Command="{Binding ApproveDraftCommand}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Style="{StaticResource VioletButtonStyle}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding CanGeneratePdf, Mode=OneWay}"
                                 Margin="0,8,0,0">
                <Button Text="Generate PDF"
                        Command="{Binding GeneratePdfCommand}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Style="{StaticResource VioletButtonStyle}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding CanOpenPdf, Mode=OneWay}"
                                 Margin="0,8,0,0">
                <Button Text="Open / Download PDF"
                        Command="{Binding OpenPdfCommand}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Style="{StaticResource VioletButtonStyle}" />
            </VerticalStackLayout>

            <Label IsVisible="{Binding ShowPdfRetry}"
                   Text="PDF generation failed. You can retry."
                   TextColor="{StaticResource DangerRed}" />

            <Border IsVisible="{Binding IsApproved}"
                    Padding="12,8"
                    Stroke="{AppThemeBinding Light={StaticResource ApprovalTextLight}, Dark={StaticResource ApprovalTextDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ApprovalBoxBgLight}, Dark={StaticResource ApprovalBoxBgDark}}"
                    StrokeShape="RoundRectangle 8"
                    Margin="0,16,0,0">
                <Label Text="✓ Resume approved and locked for PDF generation"
                       FontSize="13"
                       FontFamily="OpenSansSemibold"
                       TextColor="{AppThemeBinding Light={StaticResource ApprovalTextLight}, Dark={StaticResource ApprovalTextDark}}" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
