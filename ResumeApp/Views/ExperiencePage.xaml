<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             xmlns:models="clr-namespace:ResumeApp.Models"
             x:Class="ResumeApp.Views.ExperiencePage"
             x:DataType="vm:ExperienceViewModel"
             x:Name="ExperiencePageRoot"
             Title="Experience"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">

            <controls:PageHeader Title="Experience" />

            <Label FontSize="26"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="&#xf0b1; " FontFamily="FASolid" />
                        <Span Text="Experience" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="Add your work history, roles, and achievements."
                   Style="{StaticResource SubtitleStyle}" />

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Company *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Company"
                           Text="{Binding CurrentExperience.Company}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="Job Title *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Job Title"
                           Text="{Binding CurrentExperience.JobTitle}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Employment Type (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <Picker Title="Employment Type"
                                    ItemsSource="{Binding EmploymentTypes}"
                                    SelectedItem="{Binding CurrentExperience.EmploymentType}">
                                <Picker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="SelectedIndexChanged"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </Picker.Behaviors>
                            </Picker>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Location (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <Entry Placeholder="Location"
                                   Text="{Binding CurrentExperience.Location}"
                                   PlaceholderColor="{StaticResource InactiveIcon}">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </Entry.Behaviors>
                            </Entry>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Start Date *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker Date="{Binding CurrentExperience.StartDate}">
                                <DatePicker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="DateSelected"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </DatePicker.Behaviors>
                            </DatePicker>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="End Date *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker Date="{Binding CurrentExperience.EndDate}">
                                <DatePicker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="DateSelected"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </DatePicker.Behaviors>
                            </DatePicker>
                        </VerticalStackLayout>
                    </Grid>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding CurrentExperience.IsCurrentJob}"
                                  Color="{StaticResource PrimaryViolet}">
                            <CheckBox.Behaviors>
                                <toolkit:EventToCommandBehavior EventName="CheckedChanged"
                                                                Command="{Binding MarkDirtyCommand}" />
                            </CheckBox.Behaviors>
                        </CheckBox>
                        <Label Text="I currently work here"
                               VerticalOptions="Center"
                               TextColor="{StaticResource TextPrimary}" />
                    </HorizontalStackLayout>

                    <Label Text="Technologies (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Technologies, e.g. C#, Azure, SQL"
                           Text="{Binding CurrentExperience.Technologies}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="Description *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Editor Placeholder="Describe responsibilities and achievements"
                            AutoSize="TextChanges"
                            Text="{Binding CurrentExperience.Description}"
                            PlaceholderColor="{StaticResource InactiveIcon}">
                        <Editor.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Editor.Behaviors>
                    </Editor>

                    <Label Text="{Binding FormValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasFormValidation}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddExperienceCommand}"
                            Style="{StaticResource VioletButtonStyle}" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   IsVisible="{Binding HasError}" />

            <Label Text="Saved entries"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding ExperienceEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No experience entries added yet."
                           Style="{StaticResource SubtitleStyle}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ExperienceEntry">
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="{StaticResource SurfaceWhite}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding JobTitle}"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Company}"
                                       TextColor="{StaticResource PrimaryViolet}"
                                       FontSize="14" />
                                <Label Text="{Binding Location}"
                                       Style="{StaticResource SubtitleStyle}" />
                                <Label Text="{Binding DurationText}"
                                       FontSize="12"
                                       TextColor="{StaticResource InactiveIcon}" />
                                <Label Text="{Binding Technologies}"
                                       FontSize="12"
                                       TextColor="{StaticResource SecondaryBlue}" />
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0"
                                            Text="Edit"
                                            x:DataType="{x:Null}"
                                            Command="{Binding Source={x:Reference ExperiencePageRoot}, Path=BindingContext.EditExperienceCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36" />
                                    <Button Grid.Column="1"
                                            Text="Delete"
                                            x:DataType="{x:Null}"
                                            Command="{Binding Source={x:Reference ExperiencePageRoot}, Path=BindingContext.DeleteExperienceCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            HeightRequest="36" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
