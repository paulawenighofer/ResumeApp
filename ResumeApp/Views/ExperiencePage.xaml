<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.ExperiencePage"
             x:Name="ExperiencePageRoot"
             Title="Experience"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Experience"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A1A2E" />

            <Label Text="Lege Positionen, Aufgaben und Technologien strukturiert an."
                   FontSize="14"
                   TextColor="#6C757D" />

            <Border BackgroundColor="White"
                    Stroke="#DEE2E6"
                    StrokeShape="RoundRectangle 16"
                    Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Company"
                           Text="{Binding CurrentExperience.Company}" />
                    <Entry Placeholder="Job Title"
                           Text="{Binding CurrentExperience.JobTitle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Picker Grid.Column="0"
                                Title="Employment Type"
                                ItemsSource="{Binding EmploymentTypes}"
                                SelectedItem="{Binding CurrentExperience.EmploymentType}" />
                        <Entry Grid.Column="1"
                               Placeholder="Location"
                               Text="{Binding CurrentExperience.Location}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding CurrentExperience.StartDate}" />
                        <DatePicker Grid.Column="1"
                                    Date="{Binding CurrentExperience.EndDate}" />
                    </Grid>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding CurrentExperience.IsCurrentJob}" />
                        <Label Text="I currently work here"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Entry Placeholder="Technologies, e.g. C#, Azure, SQL"
                           Text="{Binding CurrentExperience.Technologies}" />

                    <Editor Placeholder="Describe responsibilities and achievements"
                            AutoSize="TextChanges"
                            Text="{Binding CurrentExperience.Description}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddExperienceCommand}"
                            BackgroundColor="#1A1A2E"
                            TextColor="White" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            BackgroundColor="#E9ECEF"
                            TextColor="#1A1A2E" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="#DC3545"
                   IsVisible="{Binding HasError}" />

            <CollectionView ItemsSource="{Binding ExperienceEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No experience entries added yet."
                           TextColor="#6C757D" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="White"
                                Stroke="#DEE2E6"
                                StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding JobTitle}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Company}" />
                                <Label Text="{Binding Location}"
                                       TextColor="#6C757D" />
                                <Label Text="{Binding DurationText}"
                                       FontSize="12"
                                       TextColor="#6C757D" />
                                <Label Text="{Binding Technologies}"
                                       FontSize="12"
                                       TextColor="#0A66C2" />
                                <Label Text="{Binding Description}" />
                                <Button Text="Delete"
                                        Command="{Binding Source={x:Reference ExperiencePageRoot}, Path=BindingContext.DeleteExperienceCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FFF1F3"
                                        TextColor="#B42318" />
                                <Button Text="Edit"
                                        Command="{Binding Source={x:Reference ExperiencePageRoot}, Path=BindingContext.EditExperienceCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#E7F1FF"
                                        TextColor="#0A66C2" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Continue to Skills"
                    Command="{Binding SaveAndContinueCommand}"
                    BackgroundColor="#198754"
                    TextColor="White" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
