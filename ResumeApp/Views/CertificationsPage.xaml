<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             xmlns:models="clr-namespace:ResumeApp.Models"
             x:Class="ResumeApp.Views.CertificationsPage"
             x:DataType="vm:CertificationsViewModel"
             x:Name="CertificationsPageRoot"
             Title="Certifications"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">

            <controls:PageHeader Title="Certifications" />

            <Label FontSize="26"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="&#xf0a3; " FontFamily="FASolid" />
                        <Span Text="Certifications" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="Add certifications and credentials you've earned."
                   Style="{StaticResource SubtitleStyle}" />

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Certification Name *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Certification name"
                           Text="{Binding CurrentCertification.Name}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="Issuing Organization *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Issuing organization"
                           Text="{Binding CurrentCertification.IssuingOrganization}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Issue Date *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker Date="{Binding CurrentCertification.IssueDate}">
                                <DatePicker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="DateSelected"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </DatePicker.Behaviors>
                            </DatePicker>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Expiration Date *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <DatePicker Date="{Binding CurrentCertification.ExpirationDate}">
                                <DatePicker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="DateSelected"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </DatePicker.Behaviors>
                            </DatePicker>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Credential ID (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Credential ID"
                           Text="{Binding CurrentCertification.CredentialId}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="Credential URL (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="Credential URL"
                           Text="{Binding CurrentCertification.CredentialUrl}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="{Binding FormValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasFormValidation}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddCertificationCommand}"
                            Style="{StaticResource VioletButtonStyle}" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   IsVisible="{Binding HasError}" />

            <Label Text="Saved certifications"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding CertificationEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No certifications added yet."
                           Style="{StaticResource SubtitleStyle}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:CertificationEntry">
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="{StaticResource SurfaceWhite}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding IssuingOrganization}"
                                       TextColor="{StaticResource PrimaryViolet}"
                                       FontSize="14" />
                                <Label Text="{Binding ValidityText}"
                                       FontSize="12"
                                       TextColor="{StaticResource InactiveIcon}" />
                                <Label Text="{Binding CredentialId}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding CredentialUrl}"
                                       FontSize="12"
                                       TextColor="{StaticResource SecondaryBlue}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0"
                                            Text="Edit"
                                            x:DataType="{x:Null}"
                                            Command="{Binding Source={x:Reference CertificationsPageRoot}, Path=BindingContext.EditCertificationCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36" />
                                    <Button Grid.Column="1"
                                            Text="Delete"
                                            x:DataType="{x:Null}"
                                            Command="{Binding Source={x:Reference CertificationsPageRoot}, Path=BindingContext.DeleteCertificationCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            HeightRequest="36" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
