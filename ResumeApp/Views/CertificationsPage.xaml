<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.CertificationsPage"
             x:Name="CertificationsPageRoot"
             Title="Certifications"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">
            <Label Text="Certifications" FontSize="26" FontFamily="OpenSansSemibold" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Certification name" Text="{Binding CurrentCertification.Name}" />
                    <Entry Placeholder="Issuing organization" Text="{Binding CurrentCertification.IssuingOrganization}" />
                    <Entry Placeholder="Credential ID" Text="{Binding CurrentCertification.CredentialId}" />
                    <Entry Placeholder="Credential URL" Text="{Binding CurrentCertification.CredentialUrl}" />
                    <Button Text="{Binding SubmitButtonText}" Command="{Binding AddCertificationCommand}" Style="{StaticResource VioletButtonStyle}" />
                    <Button Text="Cancel edit" Command="{Binding CancelEditCommand}" IsVisible="{Binding IsEditing}" Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>
            <CollectionView ItemsSource="{Binding CertificationEntries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="16" BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource CardBorder}" StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" />
                                <Label Text="{Binding IssuingOrganization}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Grid.Column="0" Text="Edit" Command="{Binding Source={x:Reference CertificationsPageRoot}, Path=BindingContext.EditCertificationCommand}" CommandParameter="{Binding .}" Style="{StaticResource OutlineButtonStyle}" />
                                    <Button Grid.Column="1" Text="Delete" Command="{Binding Source={x:Reference CertificationsPageRoot}, Path=BindingContext.DeleteCertificationCommand}" CommandParameter="{Binding .}" Style="{StaticResource DangerButtonStyle}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="Save" Command="{Binding SaveAndContinueCommand}" Style="{StaticResource VioletButtonStyle}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
