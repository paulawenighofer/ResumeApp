<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.ProjectsPage"
             x:Name="ProjectsPageRoot"
             Title="Projects"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Projects"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A1A2E" />

            <Border BackgroundColor="White"
                    Stroke="#DEE2E6"
                    StrokeShape="RoundRectangle 16"
                    Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Project name"
                           Text="{Binding CurrentProject.Name}" />

                    <Picker Title="Project type"
                            ItemsSource="{Binding ProjectTypes}"
                            SelectedItem="{Binding CurrentProject.ProjectType}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding CurrentProject.StartDate}" />
                        <DatePicker Grid.Column="1"
                                    Date="{Binding CurrentProject.EndDate}" />
                    </Grid>

                    <Entry Placeholder="Technologies"
                           Text="{Binding CurrentProject.Technologies}" />

                    <Entry Placeholder="Project URL"
                           Text="{Binding CurrentProject.ProjectUrl}" />

                    <Editor Placeholder="Project description"
                            AutoSize="TextChanges"
                            Text="{Binding CurrentProject.Description}" />

                    <Button Text="Select project images"
                            Command="{Binding SelectProjectImagesCommand}"
                            BackgroundColor="#E7F1FF"
                            TextColor="#0A66C2" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddProjectCommand}"
                            BackgroundColor="#1A1A2E"
                            TextColor="White" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            BackgroundColor="#E9ECEF"
                            TextColor="#1A1A2E" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="#DC3545"
                   IsVisible="{Binding HasError}" />

            <CollectionView ItemsSource="{Binding ProjectEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No projects added yet."
                           TextColor="#6C757D" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="White"
                                Stroke="#DEE2E6"
                                StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding ProjectType}"
                                       TextColor="#0A66C2" />
                                <Label Text="{Binding DurationText}"
                                       FontSize="12"
                                       TextColor="#6C757D" />
                                <Label Text="{Binding Technologies}"
                                       FontSize="12"
                                       TextColor="#6C757D" />
                                <Label Text="{Binding Description}" />
                                <Label Text="Images selected"
                                       FontSize="12"
                                       TextColor="#198754"
                                       IsVisible="{Binding HasImages}" />
                                <Button Text="Delete"
                                        Command="{Binding Source={x:Reference ProjectsPageRoot}, Path=BindingContext.DeleteProjectCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FFF1F3"
                                        TextColor="#B42318" />
                                <Button Text="Edit"
                                        Command="{Binding Source={x:Reference ProjectsPageRoot}, Path=BindingContext.EditProjectCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#E7F1FF"
                                        TextColor="#0A66C2" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Save everything"
                    Command="{Binding SaveAndContinueCommand}"
                    BackgroundColor="#198754"
                    TextColor="White" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
