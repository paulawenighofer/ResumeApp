<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.ProjectsPage"
             x:Name="ProjectsPageRoot"
             Title="Projects"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">

            <Label Text="🚀 Projects"
                   FontSize="26"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Add your portfolio and side projects."
                   Style="{StaticResource SubtitleStyle}" />

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Project name"
                           Text="{Binding CurrentProject.Name}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Picker Title="Project type"
                            ItemsSource="{Binding ProjectTypes}"
                            SelectedItem="{Binding CurrentProject.ProjectType}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding CurrentProject.StartDate}" />
                        <DatePicker Grid.Column="1"
                                    Date="{Binding CurrentProject.EndDate}" />
                    </Grid>

                    <Entry Placeholder="Technologies"
                           Text="{Binding CurrentProject.Technologies}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Entry Placeholder="Project URL"
                           Text="{Binding CurrentProject.ProjectUrl}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Editor Placeholder="Project description"
                            AutoSize="TextChanges"
                            Text="{Binding CurrentProject.Description}"
                            PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddProjectCommand}"
                            Style="{StaticResource VioletButtonStyle}" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   IsVisible="{Binding HasError}" />

            <Label Text="Saved projects"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding ProjectEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No projects added yet."
                           Style="{StaticResource SubtitleStyle}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="{StaticResource SurfaceWhite}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding ProjectType}"
                                       TextColor="{StaticResource PrimaryViolet}"
                                       FontSize="14" />
                                <Label Text="{Binding DurationText}"
                                       FontSize="12"
                                       TextColor="{StaticResource InactiveIcon}" />
                                <Label Text="{Binding Technologies}"
                                       FontSize="12"
                                       TextColor="{StaticResource SecondaryBlue}" />
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0"
                                            Text="Edit"
                                            Command="{Binding Source={x:Reference ProjectsPageRoot}, Path=BindingContext.EditProjectCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36" />
                                    <Button Grid.Column="1"
                                            Text="Delete"
                                            Command="{Binding Source={x:Reference ProjectsPageRoot}, Path=BindingContext.DeleteProjectCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            HeightRequest="36" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Save"
                    Command="{Binding SaveAndContinueCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,4,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
