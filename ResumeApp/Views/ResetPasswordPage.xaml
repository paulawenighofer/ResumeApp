<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.ResetPasswordPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="24,60,24,24"
            VerticalOptions="Center">

            <!-- Form state -->
            <VerticalStackLayout IsVisible="{Binding ResetSucceeded, Converter={StaticResource InverseBoolConverter}}"
                                 Spacing="16">

                <Label Text="Reset Your Password"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1A1A2E" />

                <Label Text="Enter the 6-digit code sent to your email and choose a new password."
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6C757D"
                       Margin="0,0,0,24" />

                <Frame BorderColor="#DEE2E6" BackgroundColor="White"
                       CornerRadius="8" Padding="4,0" HasShadow="False">
                    <Entry Placeholder="6-digit reset code"
                           Keyboard="Numeric"
                           MaxLength="6"
                           Text="{Binding Code}"
                           FontSize="15" TextColor="#1A1A2E"
                           PlaceholderColor="#ADB5BD" />
                </Frame>

                <Frame BorderColor="#DEE2E6" BackgroundColor="White"
                       CornerRadius="8" Padding="4,0" HasShadow="False">
                    <Entry Placeholder="New password"
                           IsPassword="True"
                           Text="{Binding NewPassword}"
                           FontSize="15" TextColor="#1A1A2E"
                           PlaceholderColor="#ADB5BD" />
                </Frame>

                <Frame BorderColor="#DEE2E6" BackgroundColor="White"
                       CornerRadius="8" Padding="4,0" HasShadow="False">
                    <Entry Placeholder="Confirm new password"
                           IsPassword="True"
                           Text="{Binding ConfirmPassword}"
                           FontSize="15" TextColor="#1A1A2E"
                           PlaceholderColor="#ADB5BD" />
                </Frame>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#DC3545"
                       FontSize="13"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasError}" />

                <Button Text="Reset Password"
                        Command="{Binding ResetPasswordCommand}"
                        BackgroundColor="#1A1A2E"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="50"
                        Margin="0,8,0,0" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#1A1A2E"
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>

            <!-- Success state -->
            <VerticalStackLayout IsVisible="{Binding ResetSucceeded}"
                                 Spacing="16">

                <Label Text="Password Reset!"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1A1A2E" />

                <Label Text="Your password has been updated. You can now sign in with your new password."
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6C757D"
                       Margin="0,0,0,24" />

                <Button Text="Sign In"
                        Command="{Binding GoToLoginCommand}"
                        BackgroundColor="#1A1A2E"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="50" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
