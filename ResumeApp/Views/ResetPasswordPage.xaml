<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.ResetPasswordPage"
             x:DataType="vm:ResetPasswordViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="28,40,28,28" VerticalOptions="Center">

            <controls:PageHeader Title="Reset Password" />

            <VerticalStackLayout IsVisible="{Binding ResetSucceeded, Converter={StaticResource InverseBoolConverter}}"
                                 Spacing="14">

                <Label Text="&#xf023;"
                       FontFamily="FASolid"
                       FontSize="56"
                       HorizontalOptions="Center" />

                <Label Text="Reset Your Password"
                       FontSize="26"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextPrimary}" />

                <Label Text="Enter the 6-digit code sent to your email and choose a new password."
                       Style="{StaticResource SubtitleStyle}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,16" />

                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource CardBorder}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 12"
                        Padding="4,0">
                    <Entry Placeholder="6-digit reset code"
                           Keyboard="Numeric"
                           MaxLength="6"
                           Text="{Binding Code}"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />
                </Border>

                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource CardBorder}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 12"
                        Padding="8,0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="New password"
                               IsPassword="{Binding IsNewPasswordHidden}"
                               Text="{Binding NewPassword}"
                               FontSize="15"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource InactiveIcon}" />
                        <Label Grid.Column="1"
                               Text="{Binding NewPasswordToggleIcon}"
                               FontFamily="FASolid"
                               FontSize="16"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleNewPasswordVisibilityCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource CardBorder}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 12"
                        Padding="8,0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="Confirm new password"
                               IsPassword="{Binding IsConfirmPasswordHidden}"
                               Text="{Binding ConfirmPassword}"
                               FontSize="15"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource InactiveIcon}" />
                        <Label Grid.Column="1"
                               Text="{Binding ConfirmPasswordToggleIcon}"
                               FontFamily="FASolid"
                               FontSize="16"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource DangerRed}"
                       FontSize="13"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasError}" />

                <Button Text="Reset Password"
                        Command="{Binding ResetPasswordCommand}"
                        Style="{StaticResource VioletButtonStyle}"
                        Margin="0,8,0,0">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource PrimaryViolet}" Offset="0,6" Radius="16" Opacity="0.30" />
                    </Button.Shadow>
                </Button>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource PrimaryViolet}"
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding ResetSucceeded}" Spacing="16">

                <Label Text="&#xf058;"
                       FontFamily="FASolid"
                       FontSize="64"
                       HorizontalOptions="Center" />

                <Label Text="Password Reset!"
                       FontSize="26"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextPrimary}" />

                <Label Text="Your password has been updated. You can now sign in with your new password."
                       Style="{StaticResource SubtitleStyle}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,16" />

                <Button Text="Sign In"
                        Command="{Binding GoToLoginCommand}"
                        Style="{StaticResource VioletButtonStyle}" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
