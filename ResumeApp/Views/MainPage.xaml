<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.MainPage"
             x:DataType="vm:MainPageViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,80">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Gradient header -->
                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource PrimaryViolet}"
                        Padding="24,56,24,32">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,28,28" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding Greeting}"
                                   FontSize="13"
                                   TextColor="#DDD6FE" />
                            <Label Text="{Binding UserName}"
                                   FontSize="26"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="White" />
                            <Label Text="Ready to build your next resume?"
                                   FontSize="13"
                                   TextColor="#C4B5FD"
                                   Margin="0,2,0,0" />
                        </VerticalStackLayout>

                        <!-- Avatar -->
                        <Border Grid.Column="1"
                                WidthRequest="56"
                                HeightRequest="56"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 28"
                                Stroke="#DDD6FE"
                                BackgroundColor="#7C3AED"
                                VerticalOptions="Center">
                            <Border.Shadow>
                                <Shadow Brush="#3B1D86"
                                        Offset="0,6"
                                        Radius="14"
                                        Opacity="0.35" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                            </Border.GestureRecognizers>
                            <Grid>
                                <Image Source="{Binding ProfileImageSource}"
                                       Aspect="AspectFill"
                                       IsVisible="{Binding HasProfileImage}" />
                                <Label Text="&#xf007;"
                                       FontFamily="FASolid"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="White"
                                       IsVisible="{Binding HasProfileImage, Converter={StaticResource inverseBoolean}}" />
                                <Border WidthRequest="18"
                                        HeightRequest="18"
                                        BackgroundColor="#A78BFA"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 9"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        Margin="0,0,-2,-2">
                                    <Label Text="&#xf030;"
                                           FontFamily="FASolid"
                                           FontSize="9"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Content area -->
                <VerticalStackLayout Padding="24,24,24,16" Spacing="20">

                    <!-- Quick actions -->
                    <Label Text="Quick Actions"
                           Style="{StaticResource SectionHeaderStyle}" />

                    <!-- Build Resume card -->
                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource PrimaryViolet}"
                                    Offset="0,4"
                                    Radius="20"
                                    Opacity="0.10" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="4,*" HeightRequest="82">
                            <!-- Accent strip -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource PrimaryViolet}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16,0,0,16" />
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12"
                                  Padding="16,0">
                                <Border Grid.Column="0"
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource CardIconBgLight}, Dark={StaticResource CardIconBgDark}}"
                                        VerticalOptions="Center">
                                    <Label Text="&#xf15b;"
                                           FontFamily="FASolid"
                                           FontSize="16"
                                           TextColor="{StaticResource PrimaryViolet}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Generate Resume"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                    <Label Text="Build an AI-optimized resume"
                                           Style="{StaticResource SubtitleStyle}"
                                           FontSize="12" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="&#xf054;"
                                       FontFamily="FASolid"
                                       FontSize="18"
                                       TextColor="{StaticResource PrimaryViolet}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToGenerateResumeCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Profile sections row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <!-- Skills card -->
                        <Border Grid.Column="0"
                                Style="{StaticResource CardStyle}"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToSkillsCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="&#xf005;" FontFamily="FASolid" FontSize="28" />
                                <Label Text="Skills"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                <Label Text="Add &amp; manage"
                                       Style="{StaticResource SubtitleStyle}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Projects card -->
                        <Border Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToProjectsCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="&#xf135;" FontFamily="FASolid" FontSize="28" />
                                <Label Text="Projects"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                <Label Text="Showcase work"
                                       Style="{StaticResource SubtitleStyle}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <!-- Profile completion -->
                    <Label Text="Profile Completion"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0,4,0,0" />

                    <!-- Education progress -->
                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToEducationCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                            <Border WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource IconBgVioletLight}, Dark={StaticResource IconBgVioletDark}}">
                                <Label Text="&#xf19d;" FontFamily="FASolid" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Education"
                                       FontSize="14"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                <ProgressBar Progress="{Binding EducationCompletionProgress}"
                                             ProgressColor="{StaticResource PrimaryViolet}"
                                             HeightRequest="6" />
                                <Label Text="{Binding EducationEntryCount, StringFormat='{}{0}/2 entries'}"
                                       Style="{StaticResource SubtitleStyle}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="{Binding EducationCompletionText}"
                                   FontSize="13"
                                   TextColor="{StaticResource PrimaryViolet}"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Experience progress -->
                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToExperienceCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                            <Border WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource IconBgBlueLight}, Dark={StaticResource IconBgBlueDark}}">
                                <Label Text="&#xf0b1;" FontFamily="FASolid" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Experience"
                                       FontSize="14"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                <ProgressBar Progress="{Binding ExperienceCompletionProgress}"
                                             ProgressColor="{StaticResource SecondaryBlue}"
                                             HeightRequest="6" />
                                <Label Text="{Binding ExperienceEntryCount, StringFormat='{}{0}/2 entries'}"
                                       Style="{StaticResource SubtitleStyle}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="{Binding ExperienceCompletionText}"
                                   FontSize="13"
                                   TextColor="{StaticResource SecondaryBlue}"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom nav bar -->
        <controls:BottomNavBar Grid.Row="1" VerticalOptions="End" />
    </Grid>
</ContentPage>
