<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             x:Class="ResumeApp.Views.MainPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,80">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Gradient header -->
                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource PrimaryViolet}"
                        Padding="24,56,24,32">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,28,28" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding Greeting}"
                                   FontSize="13"
                                   TextColor="#DDD6FE" />
                            <Label Text="{Binding UserName}"
                                   FontSize="26"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="White" />
                            <Label Text="Ready to build your next resume?"
                                   FontSize="13"
                                   TextColor="#C4B5FD"
                                   Margin="0,2,0,0" />
                        </VerticalStackLayout>

                        <!-- Avatar -->
                        <Border Grid.Column="1"
                                WidthRequest="52"
                                HeightRequest="52"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 26"
                                Stroke="#C4B5FD"
                                BackgroundColor="#7C3AED"
                                VerticalOptions="Center">
                            <Grid>
                                <Image Source="{Binding ProfileImageSource}"
                                       Aspect="AspectFill" />
                                <Label Text="👤"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ProfileImageSource, Converter={StaticResource inverseBoolean}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Content area -->
                <VerticalStackLayout Padding="24,24,24,16" Spacing="20">

                    <!-- Quick actions -->
                    <Label Text="Quick Actions"
                           Style="{StaticResource SectionHeaderStyle}" />

                    <!-- Build Resume card -->
                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource PrimaryViolet}"
                                    Offset="0,4"
                                    Radius="20"
                                    Opacity="0.10" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="4,*" HeightRequest="80">
                            <!-- Accent strip -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource PrimaryViolet}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16,0,0,16" />
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="*,Auto"
                                  Padding="16,0">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Generate Resume"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Build an AI-optimized resume"
                                           Style="{StaticResource SubtitleStyle}"
                                           FontSize="12" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="›"
                                       FontSize="22"
                                       TextColor="{StaticResource PrimaryViolet}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToGenerateResumeCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Profile sections row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <!-- Skills card -->
                        <Border Grid.Column="0"
                                Style="{StaticResource CardStyle}"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToSkillsCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="⭐" FontSize="28" />
                                <Label Text="Skills"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Add &amp; manage"
                                       Style="{StaticResource SubtitleStyle}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Projects card -->
                        <Border Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToProjectsCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="🚀" FontSize="28" />
                                <Label Text="Projects"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Showcase work"
                                       Style="{StaticResource SubtitleStyle}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <!-- Profile completion -->
                    <Label Text="Profile Completion"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0,4,0,0" />

                    <!-- Education progress -->
                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                            <Border WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#EDE9FE">
                                <Label Text="🎓" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Education"
                                       FontSize="14"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <ProgressBar Progress="0.5"
                                             ProgressColor="{StaticResource PrimaryViolet}"
                                             HeightRequest="6" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="50%"
                                   FontSize="13"
                                   TextColor="{StaticResource PrimaryViolet}"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Experience progress -->
                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                            <Border WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#DBEAFE">
                                <Label Text="💼" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Experience"
                                       FontSize="14"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <ProgressBar Progress="0.3"
                                             ProgressColor="{StaticResource SecondaryBlue}"
                                             HeightRequest="6" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="30%"
                                   FontSize="13"
                                   TextColor="{StaticResource SecondaryBlue}"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom nav bar -->
        <controls:BottomNavBar Grid.Row="1" VerticalOptions="End" />
    </Grid>
</ContentPage>
