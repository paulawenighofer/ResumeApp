<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             x:Class="ResumeApp.Views.ProfilePage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,80">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,56,24,16" Spacing="20">
                <Label Text="Profile"
                       FontSize="28"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnDefinitions="72,*" ColumnSpacing="16">
                        <Border WidthRequest="72"
                                HeightRequest="72"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 36"
                                BackgroundColor="{StaticResource Secondary}">
                            <Grid>
                                <Image Source="{Binding ProfileImageSource}" Aspect="AspectFill" />
                                <Label Text="User"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ProfileImageSource, Converter={StaticResource inverseBoolean}}" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding UserName}" FontSize="18" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding UserEmail}" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            <Button Text="Change photo"
                                    Command="{Binding PickProfileImageCommand}"
                                    Style="{StaticResource OutlineButtonStyle}"
                                    HorizontalOptions="Start"
                                    Padding="12,6"
                                    HeightRequest="34"
                                    FontSize="12"
                                    Margin="0,6,0,0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label Text="Resume Sections" Style="{StaticResource SectionHeaderStyle}" />

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToEducationCommand}" /></Border.GestureRecognizers>
                    <Label Text="Education" FontSize="16" FontFamily="OpenSansSemibold" />
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToExperienceCommand}" /></Border.GestureRecognizers>
                    <Label Text="Experience" FontSize="16" FontFamily="OpenSansSemibold" />
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToSkillsCommand}" /></Border.GestureRecognizers>
                    <Label Text="Skills" FontSize="16" FontFamily="OpenSansSemibold" />
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToProjectsCommand}" /></Border.GestureRecognizers>
                    <Label Text="Projects" FontSize="16" FontFamily="OpenSansSemibold" />
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToCertificationsCommand}" /></Border.GestureRecognizers>
                    <Label Text="Certifications" FontSize="16" FontFamily="OpenSansSemibold" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavBar Grid.Row="1" VerticalOptions="End" />
    </Grid>
</ContentPage>
