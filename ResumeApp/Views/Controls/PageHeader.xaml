<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             x:Class="ResumeApp.Views.Controls.PageHeader"
             x:DataType="controls:PageHeader"
             x:Name="Root">

    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="4,4">
        <Border WidthRequest="36"
                HeightRequest="36"
                BackgroundColor="{StaticResource SurfaceWhite}"
                Stroke="{StaticResource CardBorder}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped" />
            </Border.GestureRecognizers>
            <Label Text="&#xf053;"
                   FontFamily="FASolid"
                   FontSize="14"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>
        <Label Grid.Column="1"
               Text="{Binding Title, Source={x:Reference Root}}"
               FontFamily="OpenSansSemibold"
               FontSize="18"
               TextColor="{StaticResource TextPrimary}"
               VerticalOptions="Center" />
    </Grid>
</ContentView>
