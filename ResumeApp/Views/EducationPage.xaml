<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.EducationPage"
             x:Name="EducationPageRoot"
             Title="Education"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">

            <Label FontSize="26"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="&#xf19d; " FontFamily="FASolid" />
                        <Span Text="Education" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="Add your degrees, schools, and important details."
                   Style="{StaticResource SubtitleStyle}" />

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="School / University"
                           Text="{Binding CurrentEducation.School}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Picker Title="Degree"
                            ItemsSource="{Binding DegreeOptions}"
                            SelectedItem="{Binding CurrentEducation.Degree}" />

                    <Entry Placeholder="Field of Study"
                           Text="{Binding CurrentEducation.FieldOfStudy}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding CurrentEducation.StartDate}" />
                        <DatePicker Grid.Column="1"
                                    Date="{Binding CurrentEducation.EndDate}" />
                    </Grid>

                    <Entry Placeholder="GPA / Grade (optional)"
                           Text="{Binding CurrentEducation.GPA}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Editor Placeholder="Description, focus areas, honors"
                            AutoSize="TextChanges"
                            Text="{Binding CurrentEducation.Description}"
                            PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddEducationCommand}"
                            Style="{StaticResource VioletButtonStyle}" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   IsVisible="{Binding HasError}" />

            <Label Text="Saved entries"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding EducationEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No education entries added yet."
                           Style="{StaticResource SubtitleStyle}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="{StaticResource SurfaceWhite}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding School}"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Degree}"
                                       TextColor="{StaticResource PrimaryViolet}"
                                       FontSize="14" />
                                <Label Text="{Binding FieldOfStudy}"
                                       Style="{StaticResource SubtitleStyle}" />
                                <Label Text="{Binding DurationText}"
                                       FontSize="12"
                                       TextColor="{StaticResource InactiveIcon}" />
                                <Label Text="{Binding Description}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="13" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0"
                                            Text="Edit"
                                            Command="{Binding Source={x:Reference EducationPageRoot}, Path=BindingContext.EditEducationCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36" />
                                    <Button Grid.Column="1"
                                            Text="Delete"
                                            Command="{Binding Source={x:Reference EducationPageRoot}, Path=BindingContext.DeleteEducationCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            HeightRequest="36" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Save"
                    Command="{Binding SaveAndContinueCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,4,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
