<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             xmlns:models="clr-namespace:ResumeApp.Models"
             x:Class="ResumeApp.Views.ResumeListPage"
             x:DataType="vm:ResumeListViewModel"
             x:Name="ResumeListPageRoot"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing"
                                        Command="{Binding LoadDraftsCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="*,80">

        <RefreshView Grid.Row="0"
                     Command="{Binding LoadDraftsCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <VerticalStackLayout Padding="24,56,24,16" Spacing="20">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="My Resumes"
                                   FontSize="28"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                            <Label Text="Drafts and AI status"
                                   Style="{StaticResource SubtitleStyle}" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="New"
                                Command="{Binding GenerateResumeCommand}"
                                BackgroundColor="{StaticResource PrimaryViolet}"
                                TextColor="White"
                                CornerRadius="12"
                                Padding="16,10"
                                HeightRequest="44"
                                FontSize="14"
                                ContentLayout="Left,8"
                                VerticalOptions="Center">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="FASolid" Glyph="&#xf067;" Color="White" Size="14" />
                            </Button.ImageSource>
                        </Button>
                    </Grid>

                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           TextColor="{StaticResource DangerRed}" />

                    <VerticalStackLayout IsVisible="{Binding HasResumes}"
                                         BindableLayout.ItemsSource="{Binding Drafts}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:ResumeDraftListItem">
                                <Border Margin="0,0,0,12"
                                        Padding="16"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource Gray950}}"
                                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource Gray600}}"
                                        StrokeShape="RoundRectangle 14">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding TargetCompany}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="16"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

                                            <Border Grid.Column="1"
                                                    Padding="10,4"
                                                    Stroke="{Binding StatusColorHex}"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource StatusBadgeBgLight}, Dark={StaticResource StatusBadgeBgDark}}"
                                                    StrokeShape="RoundRectangle 12">
                                                <Label Text="{Binding StatusText}"
                                                       TextColor="{Binding StatusColorHex}"
                                                       FontSize="12"
                                                       FontFamily="OpenSansSemibold" />
                                            </Border>
                                        </Grid>

                                        <Label Grid.Row="1"
                                               Text="{Binding CreatedAtText}"
                                               FontSize="12"
                                               TextColor="{StaticResource InactiveIcon}" />

                                        <Button Grid.Row="2"
                                                Text="View Draft"
                                                x:DataType="{x:Null}"
                                                Command="{Binding Source={x:Reference ResumeListPageRoot}, Path=BindingContext.OpenDraftCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource OutlineButtonStyle}"
                                                HeightRequest="38" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Border Style="{StaticResource CardStyle}"
                            Margin="0,20,0,0"
                            IsVisible="{Binding HasResumes, Converter={StaticResource inverseBoolean}}">
                        <VerticalStackLayout Spacing="16" HorizontalOptions="Center" Padding="16">
                            <Label Text="&#xf15c;"
                                   FontFamily="FASolid"
                                   FontSize="48"
                                   HorizontalOptions="Center" />
                            <Label Text="No drafts yet"
                                   FontSize="18"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                                   HorizontalOptions="Center" />
                            <Label Text="Generate your first AI-powered draft tailored to a specific job."
                                   Style="{StaticResource SubtitleStyle}"
                                   HorizontalTextAlignment="Center"
                                   HorizontalOptions="Center" />
                            <Button Text="Generate Draft"
                                    Command="{Binding GenerateResumeCommand}"
                                    Style="{StaticResource VioletButtonStyle}"
                                    HorizontalOptions="Center"
                                    Padding="32,14" />
                        </VerticalStackLayout>
                    </Border>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource PrimaryViolet}" />
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <controls:BottomNavBar Grid.Row="1" VerticalOptions="End" />
    </Grid>
</ContentPage>
