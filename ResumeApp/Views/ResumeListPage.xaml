<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             x:Class="ResumeApp.Views.ResumeListPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,80">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,56,24,16" Spacing="20">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="My Resumes"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Tailored &amp; AI-powered"
                               Style="{StaticResource SubtitleStyle}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="New"
                            Command="{Binding GenerateResumeCommand}"
                            BackgroundColor="{StaticResource PrimaryViolet}"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="16,10"
                            HeightRequest="44"
                            FontSize="14"
                            ContentLayout="Left,8"
                            VerticalOptions="Center">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="FASolid" Glyph="&#xf067;" Color="White" Size="14" />
                        </Button.ImageSource>
                    </Button>
                </Grid>

                <!-- Empty state -->
                <Border Style="{StaticResource CardStyle}"
                        Margin="0,20,0,0">
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center" Padding="16">
                        <Label Text="&#xf15c;"
                               FontFamily="FASolid"
                               FontSize="48"
                               HorizontalOptions="Center" />
                        <Label Text="No resumes yet"
                               FontSize="18"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" />
                        <Label Text="Generate your first AI-powered resume tailored to any job."
                               Style="{StaticResource SubtitleStyle}"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center" />
                        <Button Text="Generate Resume"
                                Command="{Binding GenerateResumeCommand}"
                                Style="{StaticResource VioletButtonStyle}"
                                HorizontalOptions="Center"
                                Padding="32,14" />
                    </VerticalStackLayout>
                </Border>

                <!-- Quick tips -->
                <Label Text="Tips"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="0,8,0,0" />

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="&#xf0eb;" FontFamily="FASolid" FontSize="24" VerticalOptions="Center" />
                        <Label Text="Complete your profile sections first for better AI suggestions."
                               Style="{StaticResource SubtitleStyle}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="&#xf140;" FontFamily="FASolid" FontSize="24" VerticalOptions="Center" />
                        <Label Text="Tailor each resume to a specific job description for best results."
                               Style="{StaticResource SubtitleStyle}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom nav bar -->
        <controls:BottomNavBar Grid.Row="1" VerticalOptions="End" />
    </Grid>
</ContentPage>
