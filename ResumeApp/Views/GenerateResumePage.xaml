<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.GenerateResumePage"
             x:DataType="vm:GenerateResumeViewModel"
             Title="Generate Resume"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="20">
            <Label Text="Generate Resume" FontSize="24" FontFamily="OpenSansSemibold" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Job title" Text="{Binding JobTitle}" />
                    <Entry Placeholder="Target company (optional)" Text="{Binding TargetCompany}" />
                    <Editor Placeholder="Paste the job description here..." AutoSize="TextChanges" MinimumHeightRequest="100" Text="{Binding JobDescription}" />
                    <Picker Title="Experience level" ItemsSource="{Binding ExperienceLevels}" SelectedItem="{Binding SelectedExperienceLevel}" />
                    <Picker Title="Output format" ItemsSource="{Binding ResumeFormats}" SelectedItem="{Binding SelectedResumeFormat}" />
                    <Editor Placeholder="Write a short professional summary..." AutoSize="TextChanges" MinimumHeightRequest="80" Text="{Binding PersonalSummary}" />
                    <Button Text="Attach generated file (optional)" Command="{Binding PickResumeFileCommand}" Style="{StaticResource OutlineButtonStyle}" />
                    <Label Text="{Binding SelectedFilePath}" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}" BackgroundColor="#EDE9FE" IsVisible="{Binding HasStatus}">
                <Label Text="{Binding StatusMessage}" TextColor="{StaticResource PrimaryViolet}" HorizontalTextAlignment="Center" />
            </Border>

            <Button Text="Save Resume Draft" Command="{Binding GenerateCommand}" Style="{StaticResource VioletButtonStyle}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
