<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.GenerateResumePage"
             x:DataType="vm:GenerateResumeViewModel"
             Title="Generate Resume"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="20">

            <Label Text="Generate Resume"
                   FontSize="24"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Fill in the details below and export the form data as a PDF."
                   Style="{StaticResource SubtitleStyle}" />

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Target Job"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}" />

                    <Entry Placeholder="Job title"
                           Text="{Binding JobTitle}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Entry Placeholder="Target company (optional)"
                           Text="{Binding TargetCompany}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Job Description"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}" />
                    <Editor Placeholder="Paste the job description here for a tailored resume..."
                            AutoSize="TextChanges"
                            MinimumHeightRequest="100"
                            Text="{Binding JobDescription}"
                            PlaceholderColor="{StaticResource InactiveIcon}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Preferences"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}" />

                    <Picker Title="Experience level"
                            ItemsSource="{Binding ExperienceLevels}"
                            SelectedItem="{Binding SelectedExperienceLevel}" />

                    <Picker Title="Output format"
                            ItemsSource="{Binding ResumeFormats}"
                            SelectedItem="{Binding SelectedResumeFormat}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Personal Summary (optional)"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}" />
                    <Editor Placeholder="Write a short professional summary."
                            AutoSize="TextChanges"
                            MinimumHeightRequest="80"
                            Text="{Binding PersonalSummary}"
                            PlaceholderColor="{StaticResource InactiveIcon}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Include Sections"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IncludeEducation}" Color="{StaticResource PrimaryViolet}" />
                        <Label Grid.Column="1" Text="Education" VerticalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IncludeExperience}" Color="{StaticResource PrimaryViolet}" />
                        <Label Grid.Column="1" Text="Work Experience" VerticalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IncludeSkills}" Color="{StaticResource PrimaryViolet}" />
                        <Label Grid.Column="1" Text="Skills" VerticalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IncludeProjects}" Color="{StaticResource PrimaryViolet}" />
                        <Label Grid.Column="1" Text="Projects" VerticalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}"
                    BackgroundColor="#EDE9FE"
                    IsVisible="{Binding HasStatus}">
                <Label Text="{Binding StatusMessage}"
                       TextColor="{StaticResource PrimaryViolet}"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
            </Border>

            <Button Text="Generate PDF"
                    Command="{Binding GenerateCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,4,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
