<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.GenerateResumePage"
             x:DataType="vm:GenerateResumeViewModel"
             Title="Generate Resume"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">

    <Grid>
        <ScrollView IsEnabled="{Binding IsBusy, Converter={StaticResource inverseBoolean}}">
            <VerticalStackLayout Padding="24,16" Spacing="20">

                <controls:PageHeader Title="Generate Resume" />

                <Label FontSize="24"
                       FontFamily="OpenSansSemibold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="&#xf0d0; " FontFamily="FASolid" />
                            <Span Text="Generate Resume" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text="Enter the role and job description, then let AI build a tailored draft."
                       Style="{StaticResource SubtitleStyle}" />

                <Border Style="{StaticResource CardStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource InfoBoxBgLight}, Dark={StaticResource InfoBoxBgDark}}">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="&#xf05a;"
                               FontFamily="FASolid"
                               FontSize="14"
                               TextColor="{StaticResource PrimaryViolet}"
                               VerticalOptions="Start" />
                        <Label Text="Tip: Better job descriptions produce better resume drafts."
                               FontSize="13"
                               TextColor="{StaticResource PrimaryViolet}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Target Role"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

                        <Label Text="Job Title *"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}" />
                        <Entry Placeholder="Job title"
                               Text="{Binding JobTitle}"
                               PlaceholderColor="{StaticResource InactiveIcon}"
                               ReturnType="Next" />
                        <Label Text="{Binding JobTitleValidationMessage}"
                               TextColor="{StaticResource DangerRed}"
                               FontSize="12"
                               IsVisible="{Binding HasJobTitleValidation}" />

                        <Label Text="Target Company (optional)"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}" />
                        <Entry Placeholder="Target company"
                               Text="{Binding TargetCompany}"
                               PlaceholderColor="{StaticResource InactiveIcon}"
                               ReturnType="Done" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Job Description *"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

                        <Editor Placeholder="Paste the full job description here..."
                                AutoSize="TextChanges"
                                MinimumHeightRequest="140"
                                Text="{Binding JobDescription}"
                                PlaceholderColor="{StaticResource InactiveIcon}" />
                        <Label Text="{Binding JobDescriptionValidationMessage}"
                               TextColor="{StaticResource DangerRed}"
                               FontSize="12"
                               IsVisible="{Binding HasJobDescriptionValidation}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Personal Summary (optional)"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                        <Editor Placeholder="Add extra context you want AI to emphasize..."
                                AutoSize="TextChanges"
                                MinimumHeightRequest="90"
                                Text="{Binding PersonalSummary}"
                                PlaceholderColor="{StaticResource InactiveIcon}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Sections to include -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Include Sections"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IncludeEducation}" Color="{StaticResource PrimaryViolet}" />
                            <Label Grid.Column="1" Text="Education" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IncludeExperience}" Color="{StaticResource PrimaryViolet}" />
                            <Label Grid.Column="1" Text="Work Experience" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IncludeSkills}" Color="{StaticResource PrimaryViolet}" />
                            <Label Grid.Column="1" Text="Skills" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IncludeProjects}" Color="{StaticResource PrimaryViolet}" />
                            <Label Grid.Column="1" Text="Projects" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IncludeCertifications}" Color="{StaticResource PrimaryViolet}" />
                            <Label Grid.Column="1" Text="Certifications" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Status message -->
                <Border Style="{StaticResource CardStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource InfoBoxVioletBgLight}, Dark={StaticResource InfoBoxVioletBgDark}}"
                        IsVisible="{Binding HasStatus}">
                    <Label Text="{Binding StatusMessage}"
                           TextColor="{StaticResource PrimaryViolet}"
                           FontSize="14"
                           HorizontalTextAlignment="Center" />
                </Border>

                <!-- Generate button -->
                <Button Text="Generate Draft"
                        Command="{Binding GenerateCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource inverseBoolean}}"
                        Style="{StaticResource VioletButtonStyle}"
                        ContentLayout="Left,12"
                        Margin="0,4,0,0">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FASolid" Glyph="&#xf135;" Color="White" Size="18" />
                    </Button.ImageSource>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              InputTransparent="False">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray950}}"
                    Stroke="{StaticResource CardBorder}"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12" WidthRequest="260">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource PrimaryViolet}"
                                       HorizontalOptions="Center" />
                    <Label Text="Generating your draft..."
                           FontFamily="OpenSansSemibold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                    <Label Text="Please wait while we tailor your resume to this role."
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource InactiveIcon}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
