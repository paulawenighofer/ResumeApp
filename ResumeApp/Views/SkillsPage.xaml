<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.SkillsPage"
             x:Name="SkillsPageRoot"
             Title="Skills"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">

            <Label FontSize="26"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="&#xf005; " FontFamily="FASolid" />
                        <Span Text="Skills" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="Add your technical and soft skills."
                   Style="{StaticResource SubtitleStyle}" />

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="New skill"
                           Text="{Binding SkillInput}"
                           PlaceholderColor="{StaticResource InactiveIcon}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Picker Grid.Column="0"
                                Title="Level"
                                ItemsSource="{Binding ProficiencyLevels}"
                                SelectedItem="{Binding SelectedProficiencyLevel}" />
                        <Picker Grid.Column="1"
                                Title="Category"
                                ItemsSource="{Binding SkillCategories}"
                                SelectedItem="{Binding SelectedCategory}" />
                    </Grid>

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddSkillCommand}"
                            Style="{StaticResource VioletButtonStyle}" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <!-- Suggestions -->
            <Label Text="Suggestions"
                   Style="{StaticResource SectionHeaderStyle}" />

            <CollectionView ItemsSource="{Binding SuggestedSkills}"
                            ItemsLayout="HorizontalList"
                            HeightRequest="44">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,0"
                                BackgroundColor="#EDE9FE"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference SkillsPageRoot}, Path=BindingContext.AddSuggestedSkillCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding .}"
                                   TextColor="{StaticResource PrimaryViolet}"
                                   FontSize="13"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   IsVisible="{Binding HasError}" />

            <Label Text="Your skills"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding SkillEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No skills added yet."
                           Style="{StaticResource SubtitleStyle}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="{StaticResource SurfaceWhite}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Category}"
                                           Style="{StaticResource SubtitleStyle}" />
                                    <Label Text="{Binding ProficiencyLevel}"
                                           TextColor="{StaticResource PrimaryViolet}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                    <Button Text="Edit"
                                            Command="{Binding Source={x:Reference SkillsPageRoot}, Path=BindingContext.EditSkillCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36"
                                            Padding="12,4" />
                                    <Button Text="Delete"
                                            Command="{Binding Source={x:Reference SkillsPageRoot}, Path=BindingContext.DeleteSkillCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            HeightRequest="36"
                                            Padding="12,4" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Save"
                    Command="{Binding SaveAndContinueCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,4,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
