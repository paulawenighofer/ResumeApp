<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:ResumeApp.Views.Controls"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             xmlns:models="clr-namespace:ResumeApp.Models"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="ResumeApp.Views.SkillsPage"
             x:DataType="vm:SkillsViewModel"
             x:Name="SkillsPageRoot"
             Title="Skills"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="16">

            <controls:PageHeader Title="Skills" />

            <Label FontSize="26"
                   FontFamily="OpenSansSemibold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="&#xf005; " FontFamily="FASolid" />
                        <Span Text="Skills" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="Add your technical and soft skills."
                   Style="{StaticResource SubtitleStyle}" />

            <!-- Form card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Skill Name *" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                    <Entry Placeholder="New skill"
                           Text="{Binding SkillInput}"
                           PlaceholderColor="{StaticResource InactiveIcon}">
                        <Entry.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                            Command="{Binding MarkDirtyCommand}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Level (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <Picker Title="Level"
                                    ItemsSource="{Binding ProficiencyLevels}"
                                    SelectedItem="{Binding SelectedProficiencyLevel}">
                                <Picker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="SelectedIndexChanged"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </Picker.Behaviors>
                            </Picker>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Category (optional)" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextSecondary}" />
                            <Picker Title="Category"
                                    ItemsSource="{Binding SkillCategories}"
                                    SelectedItem="{Binding SelectedCategory}">
                                <Picker.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="SelectedIndexChanged"
                                                                    Command="{Binding MarkDirtyCommand}" />
                                </Picker.Behaviors>
                            </Picker>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="{Binding FormValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasFormValidation}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding AddSkillCommand}"
                            Style="{StaticResource VioletButtonStyle}" />

                    <Button Text="Cancel edit"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}"
                            Style="{StaticResource OutlineButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <!-- Suggestions -->
            <Label Text="Suggestions"
                   Style="{StaticResource SectionHeaderStyle}" />

            <CollectionView ItemsSource="{Binding SuggestedSkills}"
                            ItemsLayout="HorizontalList"
                            HeightRequest="44">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                        <Border Margin="0,0,8,0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource IconBgVioletLight}, Dark={StaticResource IconBgVioletDark}}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    x:DataType="{x:Null}"
                                    Command="{Binding Source={x:Reference SkillsPageRoot}, Path=BindingContext.AddSuggestedSkillCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding .}"
                                   TextColor="{StaticResource PrimaryViolet}"
                                   FontSize="13"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   IsVisible="{Binding HasError}" />

            <Label Text="Your skills"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding SkillEntries}">
                <CollectionView.EmptyView>
                    <Label Text="No skills added yet."
                           Style="{StaticResource SubtitleStyle}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SkillEntry">
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource Gray950}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource Gray600}}"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
                                    <Label Text="{Binding Category}"
                                           Style="{StaticResource SubtitleStyle}" />
                                    <Label Text="{Binding ProficiencyLevel}"
                                           TextColor="{StaticResource PrimaryViolet}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                    <Button Text="Edit"
                                            x:DataType="{x:Null}"
                                            Command="{Binding Source={x:Reference SkillsPageRoot}, Path=BindingContext.EditSkillCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            HeightRequest="36"
                                            Padding="12,4" />
                                    <Button Text="Delete"
                                            x:DataType="{x:Null}"
                                            Command="{Binding Source={x:Reference SkillsPageRoot}, Path=BindingContext.DeleteSkillCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            HeightRequest="36"
                                            Padding="12,4" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
