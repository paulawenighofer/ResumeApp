<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ResumeApp.ViewModels"
             x:Class="ResumeApp.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             x:Name="LoginPageRoot"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="28,60,28,28"
            VerticalOptions="Center">

            <!-- Logo area -->
            <Border WidthRequest="72"
                    HeightRequest="72"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource PrimaryViolet}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,4">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}"
                            Offset="0,6"
                            Radius="20"
                            Opacity="0.35" />
                </Border.Shadow>
                <Label Text="&#xf005;"
                       FontFamily="FASolid"
                       FontSize="32"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Text="Resume Builder"
                   FontSize="26"
                   FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

            <Label Text="Welcome back! Let's continue building your career story."
                   Style="{StaticResource SubtitleStyle}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10" />

            <!-- Login Form Card -->
            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,4,0,0">
                <VerticalStackLayout Spacing="10">

                    <!-- Email Field -->
                    <Label Text="Email *"
                           FontSize="13"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 12"
                            Padding="4,0">
                        <Entry Placeholder="you@example.com"
                               Keyboard="Email"
                               IsTextPredictionEnabled="True"
                               Text="{Binding Email}"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                               PlaceholderColor="{StaticResource InactiveIcon}" />
                    </Border>

                    <!-- Email Suggestions -->
                    <ScrollView Orientation="Horizontal"
                                IsVisible="{Binding ShowEmailSuggestions}"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding EmailSuggestions}"
                                               Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource EmailChipBgLight}, Dark={StaticResource EmailChipBgDark}}"
                                            Stroke="{AppThemeBinding Light={StaticResource EmailChipStrokeLight}, Dark={StaticResource EmailChipStrokeDark}}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="10,4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference LoginPageRoot}, Path=BindingContext.ApplyEmailSuggestionCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding .}"
                                               FontSize="12"
                                               TextColor="{StaticResource PrimaryViolet}" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Email Validation Message -->
                    <Label Text="{Binding EmailValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasEmailValidation}" />

                    <!-- Password Field -->
                    <Label Text="Password *"
                           FontSize="13"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextSecondary}"
                           Margin="0,4,0,0" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 12"
                            Padding="8,0">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Placeholder="Enter your password"
                                   IsPassword="{Binding IsPasswordHidden}"
                                   Text="{Binding Password}"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                                   PlaceholderColor="{StaticResource InactiveIcon}" />
                            <Label Grid.Column="1"
                                   Text="{Binding PasswordToggleIcon}"
                                   FontFamily="FASolid"
                                   FontSize="16"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>

                    <!-- Password Validation Message -->
                    <Label Text="{Binding PasswordValidationMessage}"
                           TextColor="{StaticResource DangerRed}"
                           FontSize="12"
                           IsVisible="{Binding HasPasswordValidation}" />

                    <!-- Forgot Password Link -->
                    <Label Text="Forgot password?"
                           FontSize="13"
                           TextColor="{StaticResource PrimaryViolet}"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="End">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />

            <!-- Sign In Button -->
            <Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,8,0,0">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}"
                            Offset="0,6"
                            Radius="16"
                            Opacity="0.30" />
                </Button.Shadow>
            </Button>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}"
                               HorizontalOptions="Center" />

            <!-- Divider -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,8">
                <BoxView Grid.Column="0" HeightRequest="1"
                         Color="{StaticResource CardBorder}"
                         VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="  or continue with  "
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}" />
                <BoxView Grid.Column="2" HeightRequest="1"
                         Color="{StaticResource CardBorder}"
                         VerticalOptions="Center" />
            </Grid>

            <!-- Social Login Buttons -->
            <VerticalStackLayout Spacing="10">

                <!-- Google -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceWhite}, Dark={StaticResource InputSurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource InputStrokeDark}}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 12"
                        HeightRequest="50">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoogleLoginCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="&#xf1a0;"
                               FontFamily="FABrands"
                               FontSize="20"
                               TextColor="#4285F4"
                               VerticalOptions="Center" />
                        <Label Text="Continue with Google"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                    <!-- LinkedIn -->
                    <Border Grid.Column="0"
                            BackgroundColor="#0A66C2"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="50">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LinkedInLoginCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="&#xf08c;"
                                   FontFamily="FABrands"
                                   FontSize="20"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                            <Label Text="LinkedIn"
                                   TextColor="White"
                                   FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    

                    <!-- GitHub -->
                    <Border Grid.Column="1"
                            BackgroundColor="#24292F"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="50">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GitHubLoginCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="&#xf09b;"
                                   FontFamily="FABrands"
                                   FontSize="20"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                            <Label Text="GitHub"
                                   TextColor="White"
                                   FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </Grid>
            </VerticalStackLayout>

            <!-- Sign Up Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,16,0,0">
                <Label Text="Don't have an account? "
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center" />              
                <Label Text="Sign Up"
                       FontSize="14"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource PrimaryViolet}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
