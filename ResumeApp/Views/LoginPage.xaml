<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ResumeApp.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="28,60,28,28"
            VerticalOptions="Center">

            <!-- Logo area -->
            <Border WidthRequest="72"
                    HeightRequest="72"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource PrimaryViolet}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,4">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}"
                            Offset="0,6"
                            Radius="20"
                            Opacity="0.35" />
                </Border.Shadow>
                <Label Text="&#xf005;"
                       FontFamily="FASolid"
                       FontSize="32"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Text="Resume Builder"
                   FontSize="26"
                   FontFamily="OpenSansSemibold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource TextPrimary}" />

            <Label Text="Build tailored resumes with AI"
                   Style="{StaticResource SubtitleStyle}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16" />

            <!-- Email Field -->
            <Border BackgroundColor="{StaticResource SurfaceWhite}"
                    Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Padding="4,0">
                <Entry Placeholder="Email address"
                       Keyboard="Email"
                       Text="{Binding Email}"
                       FontSize="15"
                       TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <!-- Password Field -->
            <Border BackgroundColor="{StaticResource SurfaceWhite}"
                    Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Padding="4,0">
                <Entry Placeholder="Password"
                       IsPassword="True"
                       Text="{Binding Password}"
                       FontSize="15"
                       TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource InactiveIcon}" />
            </Border>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />

            <!-- Forgot Password Link -->
            <Label Text="Forgot password?"
                   FontSize="13"
                   TextColor="{StaticResource PrimaryViolet}"
                   FontFamily="OpenSansSemibold"
                   HorizontalOptions="End">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Sign In Button -->
            <Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource VioletButtonStyle}"
                    Margin="0,8,0,0">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource PrimaryViolet}"
                            Offset="0,6"
                            Radius="16"
                            Opacity="0.30" />
                </Button.Shadow>
            </Button>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryViolet}"
                               HorizontalOptions="Center" />

            <!-- Divider -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,8">
                <BoxView Grid.Column="0" HeightRequest="1"
                         Color="{StaticResource CardBorder}"
                         VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="  or continue with  "
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}" />
                <BoxView Grid.Column="2" HeightRequest="1"
                         Color="{StaticResource CardBorder}"
                         VerticalOptions="Center" />
            </Grid>

            <!-- Social Login Buttons -->
            <VerticalStackLayout Spacing="10">

                <!-- Google -->
                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource CardBorder}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 12"
                        HeightRequest="50">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoogleLoginCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="&#xf1a0;"
                               FontFamily="FABrands"
                               FontSize="20"
                               TextColor="#4285F4"
                               VerticalOptions="Center" />
                        <Label Text="Continue with Google"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                    <!-- LinkedIn -->
                    <Border Grid.Column="0"
                            BackgroundColor="#0A66C2"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="50">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LinkedInLoginCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="&#xf08c;"
                                   FontFamily="FABrands"
                                   FontSize="20"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                            <Label Text="LinkedIn"
                                   TextColor="White"
                                   FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    

                    <!-- GitHub -->
                    <Border Grid.Column="1"
                            BackgroundColor="#24292F"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="50">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GitHubLoginCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="&#xf09b;"
                                   FontFamily="FABrands"
                                   FontSize="20"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                            <Label Text="GitHub"
                                   TextColor="White"
                                   FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </Grid>
            </VerticalStackLayout>

            <!-- Sign Up Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,16,0,0">
                <Label Text="Don't have an account? "
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center" />              
                <Label Text="Sign Up"
                       FontSize="14"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource PrimaryViolet}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
