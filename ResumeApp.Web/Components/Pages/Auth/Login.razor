@page "/login"
@rendermode InteractiveServer
@layout AuthLayout
@inject ApiClient Api
@inject IMemoryCache Cache
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IConfiguration Config

<PageTitle>Sign In — Resume Builder</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Style="font-weight:600;">Welcome back</MudText>
<MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">Sign in to your account</MudText>

@if (_errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
}

<EditForm Model="_form" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />

    <MudTextField @bind-Value="_form.Email"
                  Label="Email"
                  InputType="InputType.Email"
                  Variant="Variant.Outlined"
                  Class="mb-3"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Email"
                  For="@(() => _form.Email)" />

    <MudTextField @bind-Value="_form.Password"
                  Label="Password"
                  InputType="@_passwordInputType"
                  Variant="Variant.Outlined"
                  Class="mb-1"
                  Adornment="Adornment.End"
                  AdornmentIcon="@_passwordIcon"
                  OnAdornmentClick="TogglePassword"
                  For="@(() => _form.Password)" />

    <div class="d-flex justify-end mb-4">
        <MudLink Href="/forgot-password" Typo="Typo.caption">Forgot password?</MudLink>
    </div>

    <MudButton ButtonType="ButtonType.Submit"
               Variant="Variant.Filled"
               Color="Color.Primary"
               FullWidth="true"
               Size="Size.Large"
               Disabled="_loading"
               Class="mb-4">
        @if (_loading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
        }
        Sign In
    </MudButton>
</EditForm>

<div class="d-flex align-center my-4">
    <MudDivider Class="flex-grow-1" />
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="px-3">or continue with</MudText>
    <MudDivider Class="flex-grow-1" />
</div>

<div class="d-flex gap-2 mt-4 mb-4">
    <MudButton Variant="Variant.Outlined"
               FullWidth="true"
               StartIcon="@Icons.Custom.Brands.Google"
               OnClick='() => SocialLogin("google")'>
        Google
    </MudButton>
    <MudButton Variant="Variant.Outlined"
               FullWidth="true"
               StartIcon="@Icons.Custom.Brands.GitHub"
               OnClick='() => SocialLogin("github")'>
        GitHub
    </MudButton>
    <MudButton Variant="Variant.Outlined"
               FullWidth="true"
               StartIcon="@Icons.Custom.Brands.LinkedIn"
               OnClick='() => SocialLogin("linkedin")'>
        LinkedIn
    </MudButton>
</div>

<MudText Align="Align.Center" Typo="Typo.body2">
    Don't have an account?
    <MudLink Href="/register"> Sign up</MudLink>
</MudText>

@code {
    private readonly LoginDto _form = new();
    private bool _loading;
    private string? _errorMessage;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    protected override void OnInitialized()
    {
        _errorMessage = Error switch
        {
            "session_expired" => "Your session expired. Please sign in again.",
            "social_auth_failed" => "Social login failed. Please try again.",
            _ => null
        };
    }

    private async Task HandleLogin()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var result = await Api.LoginAsync(_form);
            if (result is null)
            {
                _errorMessage = "Invalid email or password.";
                return;
            }

            var key = Guid.NewGuid().ToString("N");
            Cache.Set(key,
                new AuthSignInData(result.Token, result.Email, result.FirstName, result.LastName, result.ProfileImageUrl),
                TimeSpan.FromSeconds(30));
            Nav.NavigateTo($"/account/signin?key={key}", forceLoad: true);
        }
        catch
        {
            _errorMessage = "Unable to connect. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void TogglePassword()
    {
        if (_passwordInputType == InputType.Password)
        {
            _passwordInputType = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            _passwordInputType = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private void SocialLogin(string provider)
    {
        var apiBase = Config["ApiBaseUrl"] ?? "http://localhost:5080";
        var callbackUrl = Nav.BaseUri.TrimEnd('/') + "/auth/social-callback";
        Nav.NavigateTo($"{apiBase}/api/auth/{provider}-challenge?returnUrl={Uri.EscapeDataString(callbackUrl)}", forceLoad: true);
    }
}
