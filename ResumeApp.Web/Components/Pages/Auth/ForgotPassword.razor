@page "/forgot-password"
@rendermode InteractiveServer
@layout AuthLayout
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password — Resume Builder</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Style="font-weight:600;">Forgot password?</MudText>
<MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">
    Enter your email and we'll send you a reset code.
</MudText>

@if (_sent)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">
        Reset code sent! Check your email and follow the link to reset your password.
    </MudAlert>
    <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/reset-password">
        Enter reset code
    </MudButton>
}
else
{
    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
    }

    <EditForm Model="_form" OnValidSubmit="HandleForgot">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="_form.Email"
                      Label="Email"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Email"
                      For="@(() => _form.Email)" />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   Disabled="_loading"
                   Class="mb-4">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Send Reset Code
        </MudButton>
    </EditForm>

    <MudText Align="Align.Center" Typo="Typo.body2">
        Remember it?
        <MudLink Href="/login"> Sign in</MudLink>
    </MudText>
}

@code {
    private readonly ForgotPasswordDto _form = new();
    private bool _loading;
    private bool _sent;
    private string? _errorMessage;

    private async Task HandleForgot()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var ok = await Api.ForgotPasswordAsync(_form.Email);
            if (ok) _sent = true;
            else _errorMessage = "Could not send reset email. Check the address and try again.";
        }
        catch
        {
            _errorMessage = "Unable to connect. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}
