@page "/reset-password"
@rendermode InteractiveServer
@layout AuthLayout
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password — Resume Builder</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Style="font-weight:600;">Reset password</MudText>
<MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">
    Enter the code from your email and choose a new password.
</MudText>

@if (_success)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">
        Password reset successfully! You can now sign in.
    </MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/login">
        Sign In
    </MudButton>
}
else
{
    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
    }

    <EditForm Model="_form" OnValidSubmit="HandleReset">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="_form.Email"
                      Label="Email"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      For="@(() => _form.Email)" />

        <MudTextField @bind-Value="_form.Code"
                      Label="Reset code"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      MaxLength="6"
                      For="@(() => _form.Code)" />

        <MudTextField @bind-Value="_form.NewPassword"
                      Label="New password"
                      InputType="@_passwordInputType"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      HelperText="Minimum 8 characters"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordIcon"
                      OnAdornmentClick="TogglePassword"
                      For="@(() => _form.NewPassword)" />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Reset Password
        </MudButton>
    </EditForm>
}

@code {
    private readonly ResetPasswordDto _form = new();
    private bool _loading;
    private bool _success;
    private string? _errorMessage;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    private async Task HandleReset()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var (ok, error) = await Api.ResetPasswordAsync(_form);
            if (ok) _success = true;
            else _errorMessage = error ?? "Reset failed. The code may be invalid or expired.";
        }
        catch
        {
            _errorMessage = "Unable to connect. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void TogglePassword()
    {
        if (_passwordInputType == InputType.Password)
        {
            _passwordInputType = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            _passwordInputType = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }
}
